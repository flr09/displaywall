version: 2
renderer: NetworkManager
ethernets:
  eth0:
    dhcp4: true
    optional: true
wifis:
  # 1. Interner Raspberry Pi WLAN-Chip (Access Point / Hotspot für die Slaves)
  wlan0:
    optional: true
    addresses:
      - 192.168.10.1/24
    access-points:
      "DisplayWall-Netzwerk":
        password: "DisplayPassword123"
        mode: ap
        
  # 2. TP-Link USB WLAN-Adapter (Internet-Zugang für das Setup)
  wlan1:
    optional: true
    dhcp4: false
    addresses:
      - 192.168.198.233/24
    routes:
      - to: default
        via: 192.168.198.1  # <-- WICHTIG: Das ist die IP des Routers im Gängeviertel (Gateway). Meistens endet sie auf .1
    nameservers:
      addresses: [8.8.8.8, 1.1.1.1]
    access-points:
      "gaengeviertel":
        password: "KommInDieGaenge!"
