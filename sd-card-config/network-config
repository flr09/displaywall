version: 2
renderer: NetworkManager
ethernets:
  eth0:
    dhcp4: true
    optional: true
wifis:
  # 1. Interner Raspberry Pi WLAN-Chip (Access Point / Hotspot für die Slaves)
  wlan0:
    optional: true
    addresses:
      - 192.168.10.1/24
    access-points:
      "DisplayWall-Netzwerk":
        password: "DisplayPassword123"
        mode: ap
        
  # 2. TP-Link USB WLAN-Adapter (Internet-Zugang fuer das Setup)
  # Hier das lokale WLAN des Aufstellungsortes eintragen:
  wlan1:
    optional: true
    dhcp4: true
    access-points:
      "DEIN-WLAN-NAME":
        password: "DEIN-WLAN-PASSWORT"
